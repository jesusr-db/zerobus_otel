# Environment Variables Template
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control

# Databricks Workspace
DATABRICKS_HOST=https://<your-workspace>.cloud.databricks.com
DATABRICKS_TOKEN=<your-personal-access-token>

# Bundle Variables
TF_VAR_workspace_host=https://<your-workspace>.cloud.databricks.com
TF_VAR_warehouse_id=<your-sql-warehouse-id>
TF_VAR_alert_webhook_url=<your-webhook-url>
TF_VAR_alert_email=<your-email>
TF_VAR_service_principal_name=<service-principal-name-for-prod>

# Optional: Override catalog name
TF_VAR_catalog_name=observability_poc
