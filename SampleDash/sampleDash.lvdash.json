{
  "datasets": [
    {
      "name": "ds_financial_monthly",
      "displayName": "Financial KPIs Monthly (Q3)",
      "queryLines": [
        "SELECT month_start, region, segment, room_revenue_usd, other_revenue_usd, operating_costs_usd, ebitda_usd, occupancy_rate, adr_usd, revpar, ebitda_margin_pct, (room_revenue_usd + other_revenue_usd) AS total_revenue_usd, SUM(ebitda_usd) OVER (PARTITION BY region ORDER BY month_start ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) AS cumulative_region_ebitda_usd, (SUM(ebitda_usd) OVER ()) / NULLIF(SUM(room_revenue_usd + other_revenue_usd) OVER (), 0) AS q3_weighted_ebitda_margin_pct FROM jmr_demo.wyndham.gold_financial_kpis_monthly WHERE month_start BETWEEN DATE '2025-07-01' AND DATE '2025-09-01' ORDER BY month_start, region, segment "
      ]
    },
    {
      "name": "ds_operational_daily",
      "displayName": "Operational Daily KPIs",
      "queryLines": [
        "SELECT date, region, segment, rooms_sold, rooms_available, room_revenue_gross_usd, room_revenue_net_usd, occupancy_rate, adr_usd, revpar, AVG(revpar) OVER () AS overall_qtd_avg_revpar FROM jmr_demo.wyndham.gold_hotel_kpis_timeseries WHERE date BETWEEN DATE '2025-07-01' AND DATE '2025-09-30' ORDER BY date, region, segment "
      ]
    },
    {
      "name": "ds_booking_mix_weekly",
      "displayName": "Booking Mix Weekly",
      "queryLines": [
        "SELECT week_start, region, segment, channel, bookings, share FROM jmr_demo.wyndham.gold_booking_mix_weekly ORDER BY week_start, region, segment, channel "
      ]
    },
    {
      "name": "ds_loyalty_engagement_weekly",
      "displayName": "Loyalty Engagement Weekly",
      "queryLines": [
        "SELECT week_start, region, tier, events, member_stays, engagement_rate, AVG(engagement_rate) OVER () AS overall_qtd_engagement_rate_avg FROM jmr_demo.wyndham.gold_loyalty_engagement_timeseries ORDER BY week_start, region, tier "
      ]
    },
    {
      "name": "ds_root_cause_events",
      "displayName": "Root-Cause: Pipeline & ESG Events",
      "queryLines": [
        "SELECT event_date, event_type, region, metro, property_id, event_code, description, expected_impact FROM jmr_demo.wyndham.gold_change_alignment ORDER BY event_date, region, metro "
      ]
    }
  ],
