{
  "datasets": [
    {
      "name": "ds_service_health",
      "displayName": "Service Health Hourly",
      "queryLines": [
        "SELECT hour AS timestamp, service_name, avg_error_rate AS error_rate, avg_p95_latency_ms AS p95_latency_ms, max_p95_latency_ms AS p99_latency_ms, total_requests FROM jmr_demo.zerobus_dev.service_health_hourly WHERE hour >= CURRENT_TIMESTAMP() - INTERVAL 12 HOUR ORDER BY hour DESC"
      ]
    },
    {
      "name": "ds_traces_summary",
      "displayName": "Traces Hourly Summary",
      "queryLines": [
        "SELECT service_name, attributes['http.route'] AS http_route, attributes['http.method'] AS http_method, COUNT(*) AS request_count, AVG(duration_ms) AS avg_duration_ms, AVG(CAST(is_error AS DOUBLE)) AS error_rate FROM jmr_demo.zerobus_dev.traces_assembled_silver WHERE start_timestamp >= CURRENT_TIMESTAMP() - INTERVAL 12 HOUR GROUP BY service_name, attributes['http.route'], attributes['http.method'] ORDER BY request_count DESC LIMIT 100"
      ]
    }
  ],
  "pages": [
    {
      "name": "otel_monitoring",
      "displayName": "OpenTelemetry APM Dashboard",
      "layout": [
        {
          "widget": {
            "name": "header_intro",
            "multilineTextboxSpec": {
