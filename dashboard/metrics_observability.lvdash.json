{
  "datasets": [
    {
      "name": "ds_metrics_combined",
      "displayName": "Metrics - All Rollups",
      "queryLines": [
        "SELECT '1min' AS rollup_window, window_start AS timestamp, name, service_name, metric_type, avg_value, min_value, max_value, sample_count FROM jmr_demo.zerobus_sdp.metrics_1min_rollup WHERE window_start >= CURRENT_TIMESTAMP() - INTERVAL 2 HOUR AND service_name = 'o11y-app'",
        "UNION ALL",
        "SELECT '5min' AS rollup_window, window_start AS timestamp, name, service_name, metric_type, avg_value, min_value, max_value, sample_count FROM jmr_demo.zerobus_sdp.metrics_5min_rollup WHERE window_start >= CURRENT_TIMESTAMP() - INTERVAL 6 HOUR AND service_name = 'o11y-app'",
        "UNION ALL",
        "SELECT '1hour' AS rollup_window, window_start AS timestamp, name, service_name, metric_type, avg_value, min_value, max_value, sample_count FROM jmr_demo.zerobus_sdp.metrics_hourly_rollup WHERE window_start >= CURRENT_TIMESTAMP() - INTERVAL 24 HOUR AND service_name = 'o11y-app'",
        "ORDER BY timestamp DESC"
      ]
    },
    {
      "name": "ds_metric_names",
      "displayName": "Available Metric Names",
      "queryLines": [
        "SELECT DISTINCT name FROM jmr_demo.zerobus_sdp.metrics_1min_rollup WHERE service_name = 'o11y-app' ORDER BY name"
      ]
    }
  ],
  "pages": [
    {
      "name": "metrics_dashboard",
      "displayName": "Metrics Observability Dashboard - o11y-app",
      "layout": [
        {
          "widget": {
            "name": "header_intro",
            "multilineTextboxSpec": {
              "lines": [
                "# Metrics Observability Dashboard - o11y-app\n",
                "Real-time metrics monitoring with **Average**, **Minimum**, and **Maximum** values displayed per metric.\n",
                "Use the filters below to select rollup window and view detailed metric trends.\n"
              ]
            }
          },
          "position": {
            "x": 0,
            "y": 0,
            "width": 6,
            "height": 2
          }
        },
        {
          "widget": {
            "name": "filter_rollup_window",
            "multilineTextboxSpec": {
              "lines": [
                "**Rollup Window Filter:**\n",
                "1min (2hr) | 5min (6hr) | 1hour (24hr)\n",
                "\n",
                "Modify dataset query to filter: `WHERE rollup_window = '1min'`\n"
              ]
            }
          },
          "position": {
            "x": 0,
            "y": 2,
            "width": 3,
            "height": 2
          }
        },
        {
          "widget": {
            "name": "counter_active_metrics",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "ds_metrics_combined",
                  "fields": [
                    {
                      "name": "count_metrics",
                      "expression": "COUNT(DISTINCT `name`)"
                    }
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {
                  "fieldName": "count_metrics",
                  "displayName": "Active Metrics",
                  "format": {
                    "type": "number",
                    "decimalPlaces": {
                      "type": "max",
                      "places": 0
                    }
                  }
                }
              },
              "frame": {
                "showTitle": true,
                "title": "Total Active Metrics"
              }
            }
          },
          "position": {
            "x": 3,
            "y": 2,
            "width": 1,
            "height": 2
          }
        },
        {
          "widget": {
            "name": "counter_total_samples",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "ds_metrics_combined",
                  "fields": [
                    {
                      "name": "sum_samples",
                      "expression": "SUM(`sample_count`)"
                    }
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {
                  "fieldName": "sum_samples",
                  "displayName": "Total Samples",
                  "format": {
                    "type": "number",
                    "abbreviation": "compact",
                    "decimalPlaces": {
                      "type": "max",
                      "places": 1
                    }
                  }
                }
              },
              "frame": {
                "showTitle": true,
                "title": "Total Data Points"
              }
            }
          },
          "position": {
            "x": 4,
            "y": 2,
            "width": 2,
            "height": 2
          }
        },
        {
          "widget": {
            "name": "table_metric_list",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "ds_metrics_combined",
                  "fields": [
                    {
                      "name": "name",
                      "expression": "`name`"
                    },
                    {
                      "name": "metric_type",
                      "expression": "FIRST(`metric_type`)"
                    },
                    {
                      "name": "avg_value",
                      "expression": "AVG(`avg_value`)"
                    },
                    {
                      "name": "min_value",
                      "expression": "MIN(`min_value`)"
                    },
                    {
                      "name": "max_value",
                      "expression": "MAX(`max_value`)"
                    },
                    {
                      "name": "total_samples",
                      "expression": "SUM(`sample_count`)"
                    }
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 3,
              "widgetType": "table",
              "encodings": {
                "columns": [
                  {
                    "fieldName": "name",
                    "displayName": "Metric Name",
                    "type": "string",
                    "displayAs": "string"
                  },
                  {
                    "fieldName": "metric_type",
                    "displayName": "Type",
                    "type": "string",
                    "displayAs": "string"
                  },
                  {
                    "fieldName": "avg_value",
                    "displayName": "Avg",
                    "type": "number",
                    "displayAs": "number"
                  },
                  {
                    "fieldName": "min_value",
                    "displayName": "Min",
                    "type": "number",
                    "displayAs": "number"
                  },
                  {
                    "fieldName": "max_value",
                    "displayName": "Max",
                    "type": "number",
                    "displayAs": "number"
                  },
                  {
                    "fieldName": "total_samples",
                    "displayName": "Samples",
                    "type": "number",
                    "displayAs": "number"
                  }
                ]
              },
              "itemsPerPage": 10,
              "frame": {
                "showTitle": true,
                "title": "Metrics Summary Table"
              }
            }
          },
          "position": {
            "x": 0,
            "y": 4,
            "width": 6,
            "height": 6
          }
        },
